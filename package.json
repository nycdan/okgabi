{
  "name": "okcupid-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch src/api/server.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "simulate": "tsx scripts/simulate.ts",
    "agent:once": "tsx src/agent/agentLoop.ts --once",
    "agent:loop": "tsx src/agent/agentLoop.ts",
    "playwright:install": "playwright install chromium"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "latest",
    "cors": "latest",
    "express": "latest",
    "playwright": "latest",
    "react": "latest",
    "react-dom": "latest",
    "tsx": "latest",
    "uuid": "latest",
    "vite": "^6.4.2",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "typescript": "latest"
  }
}
